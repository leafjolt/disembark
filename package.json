{
  "name": "disembark",
  "version": "1.0.0",
  "description": "Travel itinerary app with Vue frontend and Node backend",
  "scripts": {
    "start": "npm run install:all && node backend/server.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd disembark-frontend && npm run dev",
    "build": "cd disembark-frontend && npm run build",
    "deploy": "gh-pages -d disembark-frontend/dist",
    "install:all": "npm install && cd backend && npm install && cd ../disembark-frontend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "gh-pages": "^6.3.0"
  },
  "keywords": [
    "vue",
    "node",
    "travel",
    "itinerary"
  ],
  "author": "",
  "license": "ISC"
}
